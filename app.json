{
  "expo": {
    "name": "StayEasy",
    "slug": "my-project-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "myprojectapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#25130C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mbaukwu.myprojectapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#25130C",
          "dark": {
            "backgroundColor": "#25130C"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/DM_Sans/static/DMSans-Regular.ttf",
            "./assets/fonts/DM_Serif_Display/DMSerifDisplay-Regular.ttf",
            "./assets/fonts/DM_Sans/static/DMSans-Bold.ttf",
            "./assets/fonts/DM_Sans/static/DMSans-SemiBold.ttf",
            "./assets/fonts/DM_Sans/static/DMSans-Medium.ttf"


          ]
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6d02e1d8-2659-4dd8-9d62-1ac6d87b3d8f"
      }
    },
    "owner": "mbaukwu"
  }
}
